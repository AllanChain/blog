{"hash":"gridsome","data":{"post":{"id":"154","title":"Git CheatSheet","summary":null,"body":"\n<h2>\n      <a id=\"article-force-pull\" class=\"anchor-hover\" href=\"#force-pull\">\n      #</a> Force pull</h2>\n<div class=\"highlight highlight-source-shell\"><div class=\"code-bar\">\n      <span class=\"mdi mdi-content-copy\"></span>\n      <span class=\"code-lang\">shell</span>\n      </div><pre><code>git fetch\nget reset --hard origin/master</code></pre></div>\n<h2>\n      <a id=\"article-assume-unchanged\" class=\"anchor-hover\" href=\"#assume-unchanged\">\n      #</a> Assume unchanged</h2>\n<div class=\"highlight highlight-source-shell\"><div class=\"code-bar\">\n      <span class=\"mdi mdi-content-copy\"></span>\n      <span class=\"code-lang\">shell</span>\n      </div><pre><code>git update-index --assume-unchanged exam.ple</code></pre></div>\n<h2>\n      <a id=\"article-upgrade-git-for-windows\" class=\"anchor-hover\" href=\"#upgrade-git-for-windows\">\n      #</a> Upgrade git for windows</h2>\n<div class=\"highlight highlight-source-shell\"><div class=\"code-bar\">\n      <span class=\"mdi mdi-content-copy\"></span>\n      <span class=\"code-lang\">shell</span>\n      </div><pre><code>git update-git-for-windows</code></pre></div>","createdAt":"2020-12-09T07:32:18.000Z","lastEditedAt":"2020-12-10T07:26:05.000Z","image":null,"labels":[{"id":"blog: cheatsheet"}]}},"context":{}}